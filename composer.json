{
    "name": "consultorio/sistema-medico",
    "description": "Sistema de Gestão para Clínica Médica — PHP 8 MVC",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": "^8.1",
        "dompdf/dompdf": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "scripts": {
        "post-install-cmd": [
            "php -r \"if (!is_dir('public/uploads')) mkdir('public/uploads', 0755, true);\""
        ]
    }
}